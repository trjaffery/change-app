# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit your actual secrets.

# Supabase — find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini — server-side only, never exposed to browser
GOOGLE_API_KEY=your-gemini-api-key-here

# App auth — one secret token shared across your devices
# First visit on each device: yourapp.netlify.app?token=YOUR_APP_TOKEN
APP_TOKEN=choose-a-long-random-secret-here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# The public key is sent to the browser; the private key signs each push.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
